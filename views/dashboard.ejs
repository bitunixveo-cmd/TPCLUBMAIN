<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Ads Performance Dashboard | TP Club</title>
    <meta name="description" content="Local ads performance dashboard for Google Ads and Meta Ads conversion reporting.">
    <meta name="robots" content="noindex, nofollow">
    <meta name="theme-color" content="#101B0D">
    <link rel="icon" type="image/png" href="/images/logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <link rel="stylesheet" href="/css/dashboard.css">
  </head>
  <body class="dashboard-locked">
    <section id="dashboardAuth" class="dashboard-auth" aria-label="Dashboard password required">
      <form id="dashboardAuthForm" class="dashboard-auth-card">
        <p class="report-eyebrow">Private reporting</p>
        <h1>TP Club Ads Dashboard</h1>
        <p>Enter the dashboard password to view private Google Ads and Meta Ads reporting.</p>
        <label>
          <span>Password</span>
          <input id="dashboardPassword" type="password" autocomplete="current-password" required>
        </label>
        <button class="reset-button" type="submit">Unlock Dashboard</button>
        <small id="dashboardAuthError" role="alert"></small>
      </form>
    </section>
    <main id="dashboardApp" class="report-shell" hidden>
      <header class="print-report-header" aria-hidden="true">
        <h1>TP Club Ads Performance Report</h1>
        <p id="printReportMeta">Dashboard export</p>
      </header>

      <section class="report-hero">
        <div>
          <p class="report-eyebrow">Local ads intelligence</p>
          <h1>Ads performance dashboard.</h1>
          <p class="report-intro">Track AED spend, impressions, clicks, ad-platform conversions, CTR, CPC, CPA, campaigns, creatives, keywords, and locations from one responsive dashboard.</p>
        </div>
        <div class="sync-card">
          <span class="sync-dot" aria-hidden="true"></span>
          <div>
            <strong id="syncStatus">Loading reporting data</strong>
            <span id="syncSubtext">Checking Google Ads and Meta Ads sync output.</span>
          </div>
        </div>
      </section>

      <div class="filter-toolbar">
        <button id="toggleFilters" class="action-button" type="button" aria-expanded="true" aria-controls="dashboardFilters">Hide filters</button>
        <span>Use filters to narrow platform, date, campaign, country, and conversion views. Conversions come from Google Ads and Meta Ads Manager.</span>
      </div>

      <section id="dashboardFilters" class="filter-panel" aria-label="Dashboard filters">
        <label>
          <span>Platform</span>
          <select id="platformFilter">
            <option value="all">All platforms</option>
          </select>
        </label>
        <label>
          <span>Date Preset</span>
          <select id="datePresetFilter">
            <option value="last30">Last 30 days</option>
            <option value="last7">Last 7 days</option>
            <option value="today">Today</option>
            <option value="yesterday">Yesterday</option>
            <option value="latest">Latest synced day</option>
            <option value="thisMonth">This month</option>
            <option value="previousMonth">Previous month</option>
            <option value="custom">Custom</option>
          </select>
        </label>
        <label>
          <span>Account</span>
          <select id="accountFilter">
            <option value="all">All accounts</option>
          </select>
        </label>
        <label>
          <span>Status</span>
          <select id="statusFilter">
            <option value="all">All statuses</option>
            <option value="active">Active / enabled</option>
            <option value="paused">Paused</option>
            <option value="unknown">Unknown</option>
          </select>
        </label>
        <label>
          <span>Campaign</span>
          <select id="campaignFilter">
            <option value="all">All campaigns</option>
          </select>
        </label>
        <label>
          <span>Location Type</span>
          <select id="locationTypeFilter">
            <option value="delivered">Delivered / user location</option>
            <option value="targeted">Targeted location</option>
            <option value="converting">Conversion countries</option>
            <option value="wasted">Spend no conversion</option>
            <option value="all">All location views</option>
          </select>
        </label>
        <label>
          <span>Country</span>
          <select id="locationFilter">
            <option value="all">All locations</option>
          </select>
        </label>
        <label>
          <span>Conversion Metric</span>
          <select id="conversionMetricFilter">
            <option value="all">All conversions</option>
            <option value="with-conversions">Only with conversions</option>
            <option value="zero-conversions">Only zero conversions</option>
            <option value="google">Google sign up</option>
            <option value="meta">Meta free trial</option>
          </select>
        </label>
        <label>
          <span>From</span>
          <input id="fromDate" type="date">
        </label>
        <label>
          <span>To</span>
          <input id="toDate" type="date">
        </label>
        <button id="resetFilters" class="reset-button" type="button">Reset</button>
      </section>

      <section class="action-bar" aria-label="Dashboard actions">
        <button id="refreshData" class="action-button" type="button">Refresh data</button>
        <button id="exportCsv" class="action-button" type="button">Export CSV</button>
        <button id="printReport" class="action-button" type="button">Download PDF / Print</button>
        <button id="copySummary" class="action-button" type="button">Copy Summary</button>
      </section>

      <div id="filterNotice" class="filter-notice" hidden></div>

      <div class="kpi-toolbar">
        <span id="dataThroughPill" class="pill data-through-pill">Data through —</span>
        <button id="toggleSecondaryKpis" class="show-toggle" type="button" aria-expanded="false" aria-controls="secondaryKpiGrid">More metrics</button>
      </div>

      <section class="kpi-grid kpi-grid-hero" aria-label="Key performance indicators">
        <article class="kpi-card kpi-hero">
          <span>Spend</span>
          <strong id="totalSpend">AED 0</strong>
          <em id="spendDelta" class="kpi-delta" aria-label="Spend change vs previous period"></em>
          <small id="spendNote">Across selected data</small>
        </article>
        <article class="kpi-card kpi-hero">
          <span>Conversions</span>
          <strong id="totalConversions">0</strong>
          <em id="conversionsDelta" class="kpi-delta" aria-label="Conversions change vs previous period"></em>
          <small>Google/Meta tracked</small>
        </article>
        <article class="kpi-card kpi-hero">
          <span>CPA</span>
          <strong id="costPerConversion">AED 0</strong>
          <em id="cpaDelta" class="kpi-delta" aria-label="CPA change vs previous period"></em>
          <small>Lower is better</small>
        </article>
        <article class="kpi-card kpi-hero kpi-warning">
          <span>Wasted spend</span>
          <strong id="wastedSpend">AED 0</strong>
          <em id="wasteDelta" class="kpi-delta" aria-label="Waste change vs previous period"></em>
          <small>Spend with 0 conversions</small>
        </article>
      </section>

      <section id="secondaryKpiGrid" class="kpi-grid kpi-grid-secondary" aria-label="Secondary metrics" hidden>
        <article class="kpi-card kpi-secondary">
          <span>Impressions</span>
          <strong id="totalImpressions">0</strong>
          <small>Total ad impressions</small>
        </article>
        <article class="kpi-card kpi-secondary">
          <span>Clicks</span>
          <strong id="totalClicks">0</strong>
          <small>Total ad clicks</small>
        </article>
        <article class="kpi-card kpi-secondary">
          <span>CTR</span>
          <strong id="ctr">0%</strong>
          <small>Clicks from impressions</small>
        </article>
        <article class="kpi-card kpi-secondary">
          <span>CPC</span>
          <strong id="cpc">AED 0</strong>
          <small>Average cost per click</small>
        </article>
        <article class="kpi-card kpi-secondary">
          <span>CVR</span>
          <strong id="conversionRate">0%</strong>
          <small>Conversions from clicks</small>
        </article>
      </section>

      <section class="panel executive-strip">
        <div id="executiveSnapshot" class="executive-scorecard" aria-label="Executive scorecard"></div>
      </section>

      <details class="dashboard-drawer">
        <summary>
          <span>Planning, targets & alerts</span>
          <small>Budget pacing, forecast, goals, anomalies</small>
        </summary>
        <section class="goal-panel" aria-label="Planning targets">
          <label>
            <span>Monthly budget</span>
            <input id="monthlyBudgetTarget" type="number" min="0" step="100" value="10000">
          </label>
          <label>
            <span>Target CPA</span>
            <input id="targetCpa" type="number" min="0" step="10" value="150">
          </label>
          <label>
            <span>Target CPC</span>
            <input id="targetCpc" type="number" min="0" step="0.1" value="1.5">
          </label>
          <label>
            <span>Target CVR %</span>
            <input id="targetCvr" type="number" min="0" step="0.1" value="1">
          </label>
        </section>
        <section class="report-grid drawer-grid">
          <article class="panel">
            <div class="panel-head">
              <div>
                <p class="panel-label">Budget pacing</p>
                <h2>Spend vs monthly plan</h2>
              </div>
            </div>
            <div id="budgetPacing"></div>
          </article>
          <article class="panel">
            <div class="panel-head">
              <div>
                <p class="panel-label">Forecast</p>
                <h2>End-of-month projection</h2>
              </div>
            </div>
            <div id="forecastGrid" class="management-summary"></div>
          </article>
        </section>
        <section class="report-grid drawer-grid">
          <article class="panel">
            <div class="panel-head">
              <div>
                <p class="panel-label">Goal tracking</p>
                <h2>Targets vs actuals</h2>
              </div>
            </div>
            <div id="targetScorecard" class="management-summary"></div>
          </article>
          <article class="panel">
            <div class="panel-head">
              <div>
                <p class="panel-label">Anomaly alerts</p>
                <h2>What changed</h2>
              </div>
            </div>
            <div id="anomalyGrid" class="management-summary"></div>
          </article>
        </section>
        <section class="panel management-panel">
          <div class="panel-head">
            <div>
              <p class="panel-label">Management summary</p>
              <h2>What matters right now</h2>
            </div>
          </div>
          <div id="managementSummary" class="management-summary"></div>
        </section>
      </details>

      <section class="report-grid">
        <article class="panel">
          <div class="panel-head">
            <div>
              <p class="panel-label">Trend chart</p>
              <h2>Spend & conversions by day</h2>
              <p class="panel-helper">Interactive ECharts view — click a day to filter. Hover for full KPIs.</p>
            </div>
          </div>
          <div class="chart-legend" aria-label="Trend chart legend">
            <span><i class="legend-spend"></i>Spend (bars)</span>
            <span><i class="legend-conv"></i>Conversions (line)</span>
          </div>
          <div id="trendChart" class="trend-chart echart-panel" role="img" aria-label="Daily spend and conversions chart"></div>
          <div class="trend-tabs" aria-label="Line chart metric">
            <button class="trend-tab is-active" type="button" data-trend-metric="spend">Spend</button>
            <button class="trend-tab" type="button" data-trend-metric="clicks">Clicks</button>
            <button class="trend-tab" type="button" data-trend-metric="conversions">Conversions</button>
            <button class="trend-tab" type="button" data-trend-metric="cpc">CPC</button>
            <button class="trend-tab" type="button" data-trend-metric="cpa">CPA</button>
          </div>
          <div id="metricLineChart" class="metric-line-chart echart-panel" role="img" aria-label="Selected metric trend line chart"></div>
        </article>

        <article class="panel">
          <div class="panel-head">
            <div>
              <p class="panel-label">Comparison</p>
              <h2>Period comparison</h2>
            </div>
          </div>
          <div id="comparisonGrid" class="comparison-grid"></div>
        </article>
      </section>

      <section class="report-grid main-charts">
        <article class="panel platform-panel">
          <div class="panel-head">
            <div>
              <p class="panel-label">Platform mix</p>
              <h2>Google vs Meta</h2>
              <p class="panel-helper">Click a bar to filter by platform.</p>
            </div>
            <span id="selectedRange" class="pill">Last 30 days</span>
          </div>
          <div id="platformBreakdown" class="platform-echart echart-panel" role="img" aria-label="Google vs Meta performance chart"></div>
        </article>

        <article class="panel">
          <div class="panel-head">
            <div>
              <p class="panel-label">Campaign chart</p>
              <h2>Top campaigns by spend</h2>
              <p class="panel-helper">Click a bar to open drilldown.</p>
            </div>
          </div>
          <div class="chart-legend" aria-label="Campaign chart legend">
            <span><i class="legend-google"></i>Google Ads</span>
            <span><i class="legend-meta"></i>Meta Ads</span>
          </div>
          <div id="campaignChart" class="campaign-chart echart-panel" role="img" aria-label="Top campaigns by spend chart"></div>
        </article>
      </section>

      <details class="dashboard-drawer">
        <summary>
          <span>Detailed analysis</span>
          <small>Tables, keywords, creatives, health, recommendations</small>
        </summary>

      <section class="panel">
        <div class="panel-head">
          <div>
            <p class="panel-label">Conversion path</p>
            <h2>Ad impression to tracked conversion</h2>
          </div>
        </div>
        <div id="funnelView" class="funnel-view"></div>
      </section>

      <section class="panel">
        <div class="panel-head">
          <div>
            <p class="panel-label">Accounts</p>
            <h2>Account-wise performance</h2>
            <p class="panel-helper">ECharts account comparison — click a bar to filter by account.</p>
          </div>
          <button class="show-toggle" type="button" data-toggle-list="accounts">Show all</button>
        </div>
        <div id="accountBreakdown" class="account-echart echart-panel" role="img" aria-label="Account performance chart"></div>
      </section>

      <section class="panel">
        <div class="panel-head">
          <div>
            <p class="panel-label">Campaign drilldown</p>
            <h2>Click a campaign to inspect it</h2>
          </div>
        </div>
        <div id="campaignDrilldown" class="campaign-drilldown"></div>
      </section>

      <section class="map-grid">
        <article class="panel map-panel">
          <div class="panel-head">
            <div>
              <p class="panel-label">Country map</p>
              <h2>Real map heat view</h2>
              <p class="panel-helper">Dark map with country flags. Ring color = performance, size = spend. Click or hover for KPIs.</p>
            </div>
          </div>
          <div class="chart-legend" aria-label="Map legend">
            <span><i class="legend-spend"></i>On target</span>
            <span><i class="legend-watch"></i>Watch</span>
            <span><i class="legend-waste"></i>Waste</span>
          </div>
          <div id="countryMap" class="country-map" aria-label="Country performance map"></div>
          <p id="countryTooltip" class="map-tooltip">Hover a country bubble to view KPIs.</p>
        </article>

        <article class="panel">
          <div class="panel-head">
            <div>
              <p class="panel-label">Country spend</p>
              <h2>Top countries by spend</h2>
              <p class="panel-helper">Flag labels show delivered location spend. Click to filter.</p>
            </div>
          </div>
          <div id="countrySpendChart" class="country-spend-echart echart-panel" role="img" aria-label="Country spend chart"></div>
        </article>

        <article class="panel">
          <div class="panel-head">
            <div>
              <p class="panel-label">Countries & locations</p>
              <h2>Where conversions come from</h2>
            </div>
            <button class="show-toggle" type="button" data-toggle-list="locations">Show all</button>
          </div>
          <div id="locationBreakdown" class="location-list"></div>
        </article>
      </section>

      <section class="panel">
        <div class="panel-head">
          <div>
            <p class="panel-label">Country drilldown</p>
            <h2>Top campaigns inside each country</h2>
          </div>
          <button class="show-toggle" type="button" data-toggle-list="countryDrilldown">Show all</button>
        </div>
        <div id="countryDrilldown" class="drilldown-list"></div>
      </section>

      <section class="panel">
        <div class="panel-head table-head">
          <div>
              <p class="panel-label">Campaign detail</p>
            <h2>Campaign performance</h2>
          </div>
          <div class="table-actions">
            <p class="table-note">Sorted by conversions and cost per conversion.</p>
            <button class="show-toggle" type="button" data-toggle-list="campaigns">Show all</button>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Platform</th>
                <th>Account</th>
                <th>Status</th>
                <th>Campaign</th>
                <th>Location</th>
                <th>Spend</th>
                <th>Impressions</th>
                <th>Clicks</th>
                <th>Ad Conv.</th>
                <th>CTR</th>
                <th>CPC</th>
                <th>Cost / Conv.</th>
                <th>Ad CVR</th>
              </tr>
            </thead>
            <tbody id="campaignRows"></tbody>
          </table>
        </div>
      </section>

      <section class="panel search-intel-panel">
        <div class="panel-head">
          <div>
            <p class="panel-label">Search intelligence</p>
            <h2>Keywords &amp; search queries</h2>
            <p class="table-note">Google Ads only — Meta does not expose keyword-level reporting.</p>
          </div>
        </div>
        <div class="search-intel-toolbar">
          <div class="trend-tabs search-intel-tabs" aria-label="Search intelligence views">
            <button class="trend-tab is-active" type="button" data-search-tab="waste">Waste</button>
            <button class="trend-tab" type="button" data-search-tab="winners">Winners</button>
            <button class="trend-tab" type="button" data-search-tab="keywords">All keywords</button>
            <button class="trend-tab" type="button" data-search-tab="queries">Search queries</button>
          </div>
          <label class="search-intel-filter">
            <input id="keywordMinSpendToggle" type="checkbox" checked>
            <span>Hide under AED 10 spend</span>
          </label>
          <div class="search-intel-actions">
            <button id="exportWastedKeywords" class="action-button action-button-small" type="button">Export wasted keywords</button>
            <button id="exportWastedSearchTerms" class="action-button action-button-small" type="button">Export wasted search terms</button>
            <button id="copyNegativesList" class="action-button action-button-small" type="button">Copy negatives list</button>
          </div>
        </div>
        <div id="searchIntelCharts" class="search-intel-charts">
          <div id="keywordWasteChart" class="keyword-waste-echart echart-panel" role="img" aria-label="Keyword waste chart"></div>
          <div id="searchTermWasteChart" class="search-term-waste-echart echart-panel" role="img" aria-label="Search term waste chart"></div>
          <div id="matchTypeChart" class="match-type-echart echart-panel" role="img" aria-label="Match type breakdown chart"></div>
        </div>
        <div id="searchIntelPanel" class="search-intel-panel-body"></div>
        <div id="keywordTableWrap" class="table-wrap keyword-table-wrap" hidden>
          <table class="keyword-table">
            <thead>
              <tr>
                <th>Keyword</th>
                <th>Match</th>
                <th>Spend</th>
                <th>Clicks</th>
                <th>Ad Conv.</th>
                <th>CPA</th>
                <th>Flag</th>
                <th class="col-extra">Campaign</th>
                <th class="col-extra">Ad group</th>
                <th class="col-extra">Impressions</th>
                <th class="col-extra">CTR</th>
                <th class="col-extra">CPC</th>
              </tr>
            </thead>
            <tbody id="keywordRows"></tbody>
          </table>
        </div>
        <div class="table-actions keyword-table-actions" hidden>
          <button id="toggleKeywordColumns" class="show-toggle" type="button">More columns</button>
          <button class="show-toggle" type="button" data-toggle-list="keywords">Show all</button>
        </div>
      </section>

      <section class="panel">
        <div class="panel-head table-head">
          <div>
            <p class="panel-label">Meta creative / ad level</p>
            <h2>Best and worst ads</h2>
          </div>
          <div class="table-actions">
            <p class="table-note">Meta ad-level reporting by creative/ad name where API data is available.</p>
            <button class="show-toggle" type="button" data-toggle-list="creatives">Show all</button>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Ad</th>
                <th>Ad set</th>
                <th>Campaign</th>
                <th>Location</th>
                <th>Spend</th>
                <th>Impressions</th>
                <th>Clicks</th>
                <th>Ad Conv.</th>
                <th>CTR</th>
                <th>CPC</th>
                <th>Cost / Conv.</th>
              </tr>
            </thead>
            <tbody id="creativeRows"></tbody>
          </table>
        </div>
      </section>

      <section class="panel actions-panel-wrap">
        <div class="panel-head">
          <div>
            <p class="panel-label">Actions</p>
            <h2>Scale, fix, watch</h2>
          </div>
        </div>
        <div id="actionsPanel" class="actions-panel"></div>
      </section>
      </details>
    </main>

    <div id="chartFloatingTooltip" class="chart-floating-tooltip" role="tooltip" hidden></div>

    <script>
      window.__DASHBOARD_AUTH__ = {
        passwordHash: "<%= dashboardPasswordHash %>",
        refreshEndpoint: "/dashboard/refresh-data.php",
        liveRefresh: {
          enabled: true,
          staleAfterMinutes: 20,
          apiSyncMinutes: 30,
          jsonPollMinutes: 3
        }
      };
    </script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>
    <script src="/assets/dashboard.js" type="module" defer></script>
  </body>
</html>
