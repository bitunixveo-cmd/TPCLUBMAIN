<%- include('partials/compliance-banner') %>
<header class="site-header meta-header" data-nav>
  <nav class="container nav-shell" aria-label="Primary navigation">
    <a class="brand" href="/<%= lang %>/meta/" aria-label="<%= t.a11y.home %>">
      <img src="/images/logo.png" alt="" width="44" height="44">
      <span><%= t.brand %></span>
    </a>
    <div class="language-switcher" aria-label="Language switcher">
      <a class="<%= lang === 'en' ? 'active' : '' %>" href="/en/meta/">EN</a>
      <a class="<%= lang === 'zh' ? 'active' : '' %>" href="/zh/meta/">中文</a>
    </div>
    <a class="btn-primary nav-cta meta-nav-cta" href="<%= telegramUrl %>" data-track-cta="<%= t.metaAds.navCta %>"><%= t.metaAds.navCta %></a>
  </nav>
</header>
<main class="meta-landing">
  <section class="section meta-hero" id="hero">
    <div class="container meta-hero-grid">
      <div class="meta-hero-copy">
        <p class="badge"><span class="text-icon" aria-hidden="true">TP</span> <%= t.metaAds.hero.badge %></p>
        <h1 class="meta-hero-title"><%= t.metaAds.hero.title %><% if (t.metaAds.hero.titleAccent) { %> <span><%= t.metaAds.hero.titleAccent %></span><% } %></h1>
        <p class="meta-hero-sub"><%= t.metaAds.hero.sub %></p>
        <a class="btn-primary meta-hero-cta" href="<%= telegramUrl %>" data-track-cta="<%= t.metaAds.hero.cta %>"><%= t.metaAds.hero.cta %></a>
        <p class="meta-hero-note"><%= t.metaAds.hero.note %></p>
        <div class="meta-hero-chips" aria-label="<%= t.a11y.proofPoints %>">
          <% t.metaAds.hero.chips.forEach((chip) => { %>
            <span><%= chip %></span>
          <% }) %>
        </div>
      </div>
      <div class="meta-hero-media">
        <img src="/images/meta-hero-trading.png" alt="<%= t.metaAds.hero.mediaAlt %>" width="1024" height="683" loading="eager" decoding="async">
      </div>
    </div>
  </section>

  <section class="section section-alt meta-steps">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow"><%= t.metaAds.steps.eyebrow %></p>
        <h2><%= t.metaAds.steps.title %></h2>
      </div>
      <div class="meta-steps-grid">
        <% t.metaAds.steps.items.forEach((item) => { %>
          <article class="card meta-step-card">
            <span><%= item.n %></span>
            <h3><%= item.t %></h3>
            <p><%= item.d %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </section>

  <section class="section meta-benefits" id="benefits">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow"><%= t.metaAds.benefits.eyebrow %></p>
        <h2><%= t.metaAds.benefits.title %></h2>
      </div>
      <div class="meta-benefits-grid" aria-label="<%= t.a11y.benefits %>">
        <% t.metaAds.benefits.items.forEach((item) => { %>
          <article class="card meta-benefit-card">
            <span class="meta-benefit-number"><%= item.n %></span>
            <h3><%= item.t %></h3>
            <p><%= item.d %></p>
          </article>
        <% }) %>
      </div>
      <div class="meta-benefits-cta">
        <a class="btn-primary" href="<%= telegramUrl %>" data-track-cta="<%= t.metaAds.cta.cta %>"><%= t.metaAds.cta.cta %></a>
        <p class="meta-hero-note"><%= t.metaAds.cta.note %></p>
      </div>
    </div>
  </section>

  <section class="section meta-trust">
    <div class="container trust-grid meta-trust-grid" aria-label="<%= t.trust.ariaLabel %>">
      <% t.metaAds.proof.forEach((item) => { %>
        <div class="card trust-item">
          <strong><%= item.n %></strong>
          <span><%= item.l %></span>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="section section-alt meta-preview" id="preview">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow"><%= t.metaAds.preview.eyebrow %></p>
        <h2><%= t.metaAds.preview.title %></h2>
      </div>
      <div class="meta-slider" data-slider>
        <button class="meta-slider-arrow meta-slider-prev" type="button" aria-label="<%= t.metaAds.preview.prev %>" data-slider-prev>&#8249;</button>
        <div class="meta-slider-viewport" data-slider-viewport>
          <div class="meta-slider-track" data-slider-track>
            <% t.metaAds.preview.items.forEach((item) => { %>
              <article class="card preview-card preview-card-<%= item.type %> meta-slide" data-slide>
                <button class="preview-image-link" type="button" data-community-modal-open data-community-image="<%= item.image %>" data-community-title="<%= item.t %>" aria-label="<%= t.communityPreview.openLabel %> <%= item.t %>">
                  <img src="<%= item.image %>" alt="<%= item.t %> screenshot from TP Club Telegram community" loading="lazy" decoding="async">
                  <span class="preview-overlay">
                    <span class="preview-open"><%= t.communityPreview.openLabel %></span>
                    <strong><%= item.t %></strong>
                    <span><%= item.d %></span>
                  </span>
                </button>
              </article>
            <% }) %>
          </div>
        </div>
        <button class="meta-slider-arrow meta-slider-next" type="button" aria-label="<%= t.metaAds.preview.next %>" data-slider-next>&#8250;</button>
      </div>
      <div class="meta-slider-dots" role="tablist" aria-label="<%= t.metaAds.preview.title %>" data-slider-dots></div>
      <p class="meta-slider-hint"><%= t.metaAds.preview.hint %></p>
    </div>
    <div class="community-modal" id="community-image-modal" role="dialog" aria-modal="true" aria-labelledby="community-modal-title" hidden data-community-modal>
      <button class="community-modal-backdrop" type="button" aria-label="<%= t.communityPreview.modalClose %>" data-community-modal-close></button>
      <div class="community-modal-card" role="document" tabindex="-1" data-community-modal-card>
        <button class="community-modal-close" type="button" aria-label="<%= t.communityPreview.modalClose %>" data-community-modal-close>&times;</button>
        <p class="eyebrow"><%= t.communityPreview.eyebrow %></p>
        <h2 id="community-modal-title" data-community-modal-title><%= t.communityPreview.modalTitle %></h2>
        <img src="" alt="" data-community-modal-image>
        <a class="btn-primary" href="<%= telegramUrl %>" data-track-cta="<%= t.communityPreview.modalCta %>"><%= t.communityPreview.modalCta %></a>
      </div>
    </div>
  </section>

  <section class="section section-alt meta-final-cta" id="join">
    <div class="container meta-final-cta-inner">
      <h2><%= t.metaAds.cta.title %></h2>
      <p class="muted"><%= t.metaAds.cta.sub %></p>
      <a class="btn-primary" href="<%= telegramUrl %>" data-track-cta="<%= t.metaAds.cta.cta %>"><%= t.metaAds.cta.cta %></a>
      <p class="meta-hero-note"><%= t.metaAds.cta.note %></p>
    </div>
  </section>
  <a class="meta-sticky-cta" href="<%= telegramUrl %>" data-track-cta="<%= t.metaAds.cta.cta %>"><%= t.metaAds.cta.cta %></a>
</main>
<footer class="site-footer meta-footer">
  <div class="container copyright">
    <p><%= t.metaAds.footerNote %></p>
    <p><%= t.footer.copyright %></p>
  </div>
</footer>
