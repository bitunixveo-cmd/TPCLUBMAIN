<!doctype html>
<html lang="<%= t.meta.lang %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= typeof pageTitle !== 'undefined' ? `${pageTitle} | TP Club` : t.meta.title %></title>
    <meta name="description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : t.meta.description %>">
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <link rel="canonical" href="<%= seo.canonical %>">
    <link rel="alternate" hreflang="en-AU" href="<%= seo.hrefLang.en %>">
    <link rel="alternate" hreflang="zh-Hans" href="<%= seo.hrefLang.zh %>">
    <link rel="alternate" hreflang="x-default" href="<%= seo.hrefLang.default %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= seo.ogUrl %>">
    <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? `${pageTitle} | TP Club` : t.meta.title %>">
    <meta property="og:description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : t.meta.description %>">
    <meta property="og:image" content="<%= seo.ogImage %>">
    <meta property="og:locale" content="<%= t.meta.ogLocale %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= typeof pageTitle !== 'undefined' ? `${pageTitle} | TP Club` : t.meta.title %>">
    <meta name="twitter:description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : t.meta.description %>">
    <meta name="twitter:image" content="<%= seo.ogImage %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&family=Noto+Sans+SC:wght@400;500;700&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&family=Noto+Sans+SC:wght@400;500;700&display=swap">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/layout.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/responsive.css">
    <style>
      .hero { position: relative; overflow: hidden; min-height: calc(100vh - 96px); }
      .hero::before { content: ""; position: absolute; inset: 0; background-image: radial-gradient(var(--neon-border) 1px, transparent 1px); background-size: 24px 24px; opacity: 0.36; pointer-events: none; }
      .hero::after { content: ""; position: absolute; width: 560px; height: 560px; right: -140px; top: 40px; background: radial-gradient(circle, var(--neon-glow), transparent 68%); pointer-events: none; }
      .hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr); gap: clamp(36px, 6vw, 84px); align-items: center; }
      .hero-title { margin: 18px 0; font-size: clamp(3rem, 8vw, 6.8rem); line-height: 0.92; letter-spacing: -0.08em; }
      .hero-title span { display: block; background: linear-gradient(135deg, var(--neon), var(--neon-dim), var(--neon-dark)); -webkit-background-clip: text; background-clip: text; color: transparent; }
      @media (max-width: 767px) { .hero-grid { grid-template-columns: 1fr; } }
    </style>
    <% seo.structuredData.forEach((schema) => { %>
      <script type="application/ld+json"><%- JSON.stringify(schema) %></script>
    <% }) %>
    <!-- Google Analytics / GTM can be enabled here when required. -->
  </head>
  <body class="<%= lang === 'zh' ? 'locale-zh' : 'locale-en' %>">
    <%- include(view) %>
    <script src="/js/nav.js" type="module" defer></script>
    <script src="/js/faq.js" type="module" defer></script>
    <script src="/js/price.js" type="module" defer></script>
  </body>
</html>
