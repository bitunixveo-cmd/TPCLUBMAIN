<%- include('partials/compliance-banner') %>
<%- include('partials/nav') %>
<main class="section page-shell">
  <div class="container narrow center">
    <p class="eyebrow">TP Club</p>
    <h1><%= page.title %></h1>
    <p class="page-intro"><%= page.intro %></p>
    <div class="button-row center-row">
      <a class="btn-primary" href="<%= telegramUrl %>" target="_blank" rel="noopener noreferrer"><%= page.telegram %></a>
      <a class="btn-ghost" href="<%= bookingUrl %>" target="_blank" rel="noopener noreferrer"><%= page.booking %></a>
    </div>
    <div class="card contact-card">
      <a class="text-link" href="<%= telegramChannelUrl %>" target="_blank" rel="noopener noreferrer"><%= page.channel %></a>
      <a class="text-link" href="mailto:hello@tpclub.co"><%= page.email %></a>
      <p class="microcopy"><%= page.note %></p>
    </div>
  </div>
</main>
<%- include('partials/footer') %>
