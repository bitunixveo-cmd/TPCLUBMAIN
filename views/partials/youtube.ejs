<section class="section youtube-section" id="youtube">
  <div class="container">
    <article class="card youtube-card">
      <div class="youtube-copy">
        <p class="eyebrow"><%= t.youtube.eyebrow %></p>
        <h2><%= t.youtube.title %></h2>
        <p class="muted"><%= t.youtube.sub %></p>
      </div>
      <a class="btn-primary youtube-cta" href="<%= youtubeUrl %>" target="_blank" rel="noopener noreferrer">
        <span class="youtube-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M21.6 7.1a3 3 0 0 0-2.1-2.1C17.7 4.5 12 4.5 12 4.5s-5.7 0-7.5.5a3 3 0 0 0-2.1 2.1C2 8.9 2 12 2 12s0 3.1.4 4.9A3 3 0 0 0 4.5 19c1.8.5 7.5.5 7.5.5s5.7 0 7.5-.5a3 3 0 0 0 2.1-2.1c.4-1.8.4-4.9.4-4.9s0-3.1-.4-4.9ZM10 15.2V8.8l5.5 3.2-5.5 3.2Z"></path>
          </svg>
        </span>
        <%= t.youtube.cta %>
      </a>
    </article>
  </div>
</section>
