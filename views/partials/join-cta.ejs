<section class="section join-cta" id="join">
  <div class="container narrow center">
    <p class="eyebrow">TP Club</p>
    <h2><%= t.cta.title %></h2>
    <p class="muted"><%= t.cta.sub %></p>
    <div class="button-row center-row">
      <a class="btn-primary" href="<%= telegramUrl %>" target="_blank" rel="noopener noreferrer"><%= t.cta.cta1 %></a>
