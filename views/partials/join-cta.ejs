<section class="section join-cta" id="join">
  <div class="container narrow center">
    <p class="eyebrow"><%= t.cta.eyebrow %></p>
    <h2><%= t.cta.title %></h2>
    <p class="muted"><%= t.cta.sub %></p>
    <% if (t.cta.benefits) { %>
      <div class="cta-benefits" aria-label="TP Club benefits">
        <% t.cta.benefits.forEach((benefit) => { %>
          <span><%= benefit %></span>
        <% }) %>
      </div>
    <% } %>
    <div class="button-row center-row">
      <a class="btn-primary" href="<%= telegramUrl %>" data-track-cta="<%= t.cta.cta1 %>"><%= t.cta.cta1 %></a>
    </div>
    <p class="microcopy"><%= t.cta.note %></p>
  </div>
</section>
