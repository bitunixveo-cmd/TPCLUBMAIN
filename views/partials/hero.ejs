<section class="section hero" id="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="badge"><span class="text-icon" aria-hidden="true">TP</span> <%= t.hero.badge %></p>
      <h1 class="hero-title"><%= t.hero.h1a %><span><%= t.hero.h1b %></span></h1>
      <p class="hero-sub"><%= t.hero.sub %></p>
      <div class="button-row">
        <a class="btn-primary" href="<%= telegramUrl %>" data-track-cta="<%= t.hero.cta1 %>"><%= t.hero.cta1 %></a>
        <% if (t.hero.cta2) { %>
          <a class="btn-ghost" href="#telegram-preview"><%= t.hero.cta2 %></a>
        <% } %>
      </div>
      <p class="microcopy"><%= t.hero.caption %></p>
      <div class="hero-proof-row" aria-label="<%= t.a11y.proofPoints %>">
        <% t.hero.proof.forEach((item) => { %>
          <span><%= item %></span>
        <% }) %>
      </div>
    </div>
    <div class="hero-mockup" aria-label="<%= t.hero.mockupAlt %>">
      <div class="hero-phone-wrap">
        <% (t.hero.featurePills || []).forEach((pill, index) => { %>
          <div class="hero-feature-pill pill-<%= index + 1 %>">
            <strong><%= pill.t %></strong>
            <span><%= pill.d %></span>
          </div>
        <% }) %>
        <button class="hero-image-frame hero-mockup-trigger" type="button" data-hero-modal-open aria-haspopup="dialog" aria-controls="hero-image-modal" aria-label="<%= t.a11y.openModal %>">
          <img src="<%= lang === 'zh' ? '/images/hero-community-mockup-zh.png' : '/images/hero-community-mockup.png' %>" alt="<%= t.hero.mockupAlt %>" width="1024" height="1024" loading="eager" decoding="async">
        </button>
      </div>
    </div>
  </div>
  <div class="hero-modal" id="hero-image-modal" role="dialog" aria-modal="true" aria-labelledby="hero-modal-title" hidden data-hero-modal>
    <button class="hero-modal-backdrop" type="button" aria-label="<%= t.hero.modalClose %>" data-hero-modal-close></button>
    <div class="hero-modal-card" role="document" tabindex="-1" data-hero-modal-card>
      <button class="hero-modal-close" type="button" aria-label="<%= t.hero.modalClose %>" data-hero-modal-close>&times;</button>
      <p class="eyebrow"><%= t.hero.badge %></p>
      <h2 id="hero-modal-title"><%= t.hero.modalTitle %></h2>
      <p><%= t.hero.modalText %></p>
      <a class="btn-primary" href="<%= telegramUrl %>" data-track-cta="<%= t.hero.modalCta %>"><%= t.hero.modalCta %></a>
    </div>
  </div>
</section>
