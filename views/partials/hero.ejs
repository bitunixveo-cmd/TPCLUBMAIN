<section class="section hero" id="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="badge"><span class="text-icon" aria-hidden="true">TP</span> <%= t.hero.badge %></p>
      <h1 class="hero-title"><%= t.hero.h1a %><span><%= t.hero.h1b %></span></h1>
      <p class="hero-sub"><%= t.hero.sub %></p>
      <div class="button-row">
        <a class="btn-primary" href="<%= telegramUrl %>"><%= t.hero.cta1 %></a>
      </div>
      <p class="microcopy"><%= t.hero.caption %></p>
      <div class="hero-proof-row" aria-label="TP Club proof points">
        <% t.hero.proof.forEach((item) => { %>
          <span><%= item %></span>
        <% }) %>
      </div>
    </div>
    <div class="chart-stack" aria-label="<%= t.hero.chartTitle %>">
      <div class="chart-card card">
        <div class="chart-head">
          <div>
            <p class="chart-market"><%= t.hero.priceLabel %> · <%= t.hero.chartSub %></p>
            <strong class="price" data-btc-price data-fallback="<%= t.hero.priceFallback %>">$68,420</strong>
            <span class="chart-change">&uarr; +2.4%</span>
          </div>
          <span class="chart-live-badge"><%= t.hero.liveBadge %></span>
        </div>
        <svg class="sparkline" viewBox="0 0 560 260" role="img" aria-label="<%= t.hero.chartTitle %>">
          <defs>
            <linearGradient id="chartGlow" x1="0" x2="1" y1="0" y2="0">
              <stop offset="0%" stop-color="#74D900"></stop>
              <stop offset="55%" stop-color="#AAFF00"></stop>
              <stop offset="100%" stop-color="#D7FF62"></stop>
            </linearGradient>
            <linearGradient id="chartFill" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="#AAFF00" stop-opacity="0.38"></stop>
              <stop offset="60%" stop-color="#70BD00" stop-opacity="0.15"></stop>
              <stop offset="100%" stop-color="#AAFF00" stop-opacity="0"></stop>
            </linearGradient>
          </defs>
          <g class="chart-grid">
            <line x1="28" y1="62" x2="532" y2="62"></line>
            <line x1="28" y1="116" x2="532" y2="116"></line>
            <line x1="28" y1="170" x2="532" y2="170"></line>
          </g>
          <path class="chart-area" d="M28 214 L82 198 L132 182 L176 170 L218 142 L262 120 L306 104 L352 78 L394 62 L438 40 L486 24 L532 14 L532 236 L28 236 Z"></path>
          <path class="chart-line" d="M28 214 L82 198 L132 182 L176 170 L218 142 L262 120 L306 104 L352 78 L394 62 L438 40 L486 24 L532 14"></path>
          <g class="chart-points">
            <circle cx="132" cy="182" r="4"></circle>
            <circle cx="218" cy="142" r="5"></circle>
            <circle cx="352" cy="78" r="4"></circle>
            <circle cx="486" cy="24" r="4"></circle>
            <circle class="chart-endpoint" cx="532" cy="14" r="8"></circle>
          </g>
          <g class="chart-labels">
            <text x="28" y="252"><%= t.hero.chartMonths[0] %></text>
            <text x="258" y="252"><%= t.hero.chartMonths[1] %></text>
            <text x="506" y="252"><%= t.hero.chartMonths[2] %></text>
          </g>
        </svg>
        <span class="chart-gain-pill">+42.8%</span>
      </div>
      <div class="live-strip">
        <span class="telegram-status-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M20.9 4.4 3.8 11c-.9.3-.9 1.5.1 1.8l4.2 1.3 1.6 4.8c.3.8 1.3 1 1.9.4l2.3-2.4 4.3 3.1c.7.5 1.6.1 1.7-.8l2.4-13.4c.2-.9-.6-1.7-1.4-1.4Zm-3.1 4.1-7.1 6.6-.3 2.4-1-3.2 8.4-5.8Z"></path>
          </svg>
          <span class="telegram-status-dot"></span>
        </span>
        <span><%= t.hero.live %> · <span data-price-updated><%= t.hero.updated %></span></span>
      </div>
    </div>
  </div>
</section>
