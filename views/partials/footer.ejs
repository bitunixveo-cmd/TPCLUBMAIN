<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a class="brand footer-brand" href="/<%= lang %>#hero">
        <img src="/images/logo.png" alt="TP Club Logo" width="44" height="44" loading="lazy">
        <span>TP Club</span>
      </a>
      <p class="footer-disclaimer"><%= t.footer.disclaimer %></p>
    </div>
    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/<%= lang %>#instructor"><%= t.footer.links[0] %></a>
      <a href="/<%= lang %>#how"><%= t.footer.links[1] %></a>
      <a href="/<%= lang %>#faq"><%= t.footer.links[2] %></a>
      <a href="/<%= lang %>/privacy"><%= t.footer.links[3] %></a>
      <a href="/<%= lang %>/contact"><%= t.footer.links[4] %></a>
    </nav>
  </div>
  <div class="container copyright">
    <p><%= t.footer.copyright %></p>
  </div>
</footer>
