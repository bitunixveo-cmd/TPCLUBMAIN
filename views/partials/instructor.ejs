<section class="section" id="instructor">
  <div class="container instructor-grid">
    <div class="instructor-photo" role="img" aria-label="<%= t.instructor.photo %>">
      <img src="/images/logo.png" alt="<%= t.instructor.name %>" width="220" height="220" loading="lazy">
      <span><%= t.brand %></span>
    </div>
    <div class="instructor-copy">
      <p class="eyebrow"><%= t.instructor.label %></p>
      <h2><%= t.instructor.name %></h2>
      <p class="role"><%= t.instructor.role %></p>
      <p><%= t.instructor.bio %></p>
      <div class="instructor-stats">
        <% t.instructor.stats.forEach((stat) => { %>
          <div class="stat-box">
            <strong><%= stat.n %></strong>
            <span><%= stat.l %></span>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>
