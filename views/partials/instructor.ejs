<section class="section" id="instructor">
  <div class="container instructor-grid">
    <div class="founder-card" role="img" aria-label="<%= t.instructor.photo %>">
      <div class="founder-emblem">
        <img src="/images/logo.png" alt="<%= t.instructor.founderName %>" width="148" height="148" loading="lazy">
      </div>
      <div>
        <h3><%= t.instructor.founderName %></h3>
        <p><%= t.instructor.founderRole %></p>
      </div>
      <ul>
        <% t.instructor.founderPoints.forEach((point) => { %>
          <li><%= point %></li>
        <% }) %>
      </ul>
    </div>
    <div class="instructor-copy">
      <p class="eyebrow"><%= t.instructor.label %></p>
      <h2><%= t.instructor.name %></h2>
      <p class="role"><%= t.instructor.role %></p>
      <p><%= t.instructor.bio %></p>
      <div class="instructor-stats">
        <% t.instructor.stats.forEach((stat) => { %>
          <div class="stat-box">
            <strong><%= stat.n %></strong>
            <span><%= stat.l %></span>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>
