<header class="site-header" data-nav>
  <nav class="container nav-shell" aria-label="Primary navigation">
    <a class="brand" href="/<%= lang %>#hero" aria-label="TP Club home">
      <img src="/images/logo.png" alt="" width="44" height="44">
      <span><%= t.brand %></span>
    </a>
    <div class="language-switcher mobile-language-switcher" aria-label="Mobile language switcher">
      <a class="<%= lang === 'en' ? 'active' : '' %>" href="/en/">EN</a>
      <a class="<%= lang === 'zh' ? 'active' : '' %>" href="/zh/">中文</a>
    </div>
    <button class="nav-toggle" type="button" aria-label="<%= t.nav.menu %>" aria-expanded="false" aria-controls="mobile-menu" data-nav-toggle>
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="nav-menu" id="mobile-menu" data-nav-menu>
      <a href="/<%= lang %>#instructor"><%= t.nav.links.about %></a>
      <a href="/<%= lang %>#<%= lang === 'en' ? 'telegram-preview' : 'how' %>"><%= t.nav.links.how %></a>
      <a href="/<%= lang %>#bundle"><%= t.nav.links.bundle %></a>
      <a href="/<%= lang %>#faq"><%= t.nav.links.faq %></a>
      <div class="language-switcher" aria-label="Language switcher">
        <a class="<%= lang === 'en' ? 'active' : '' %>" href="/en/">English</a>
        <a class="<%= lang === 'zh' ? 'active' : '' %>" href="/zh/">中文</a>
      </div>
      <a class="btn-primary nav-cta" href="<%= telegramUrl %>" data-track-cta="<%= t.nav.cta %>"><%= t.nav.cta %></a>
    </div>
  </nav>
</header>
