<section class="trust-section" aria-label="<%= t.trust.ariaLabel %>">
  <div class="container trust-grid">
    <% t.trust.items.forEach((item) => { %>
      <div class="trust-item">
        <strong><%= item.n %></strong>
        <span><%= item.l %></span>
      </div>
    <% }) %>
  </div>
</section>
